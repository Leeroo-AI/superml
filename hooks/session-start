#!/usr/bin/env bash
# SessionStart hook for superml plugin

set -euo pipefail

# Determine plugin root directory
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Read using-superml content
using_superml_content=$(cat "${PLUGIN_ROOT}/skills/using-superml/SKILL.md" 2>&1 || echo "Error reading using-superml skill")

# Escape string for JSON embedding using bash parameter substitution.
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

using_superml_escaped=$(escape_for_json "$using_superml_content")

# Detect missing API key and build context
kb_notice=""
if [ -z "${LEEROOPEDIA_API_KEY:-}" ]; then
    kb_notice='<USER_FACING_NOTICE>\\nYOU MUST DISPLAY THIS NOTICE TO THE USER AS THE VERY FIRST THING IN YOUR FIRST RESPONSE — before any other text, before any tool calls, before any analysis. This is not context for you; this is a message you must relay verbatim:\\n\\n> **SuperML is running in web mode** (no Leeroopedia API key detected).\\n> For full KB access (27k+ pages, faster lookups):\\n> 1. Get a free key at https://app.leeroopedia.com\\n> 2. Add to your shell: `export LEEROOPEDIA_API_KEY=kpsk_your_key`\\n> 3. Restart your coding agent\\n\\nDo NOT skip this notice. Do NOT paraphrase it. Copy the blockquote above into your response FIRST, then proceed with the task.\\n</USER_FACING_NOTICE>\\n\\n'
fi

session_context="${kb_notice}<EXTREMELY_IMPORTANT>\nYou have access to Leeroopedia, an ML/AI knowledge base with 27,667 pages from 1000+ repos.\n\nYou are a senior ML engineer who grounds decisions in documentation. Call Leeroopedia KB tools BEFORE responding to ML/AI questions — the KB has framework-specific details, version-specific gotchas, and documented patterns that general knowledge misses.\n\nIf experiments/journal.md exists in the project, read it for recent context.\n\n**Below is the full content of your 'superml:using-superml' skill — follow it exactly:**\n\n---\n\n${using_superml_escaped}\n\n</EXTREMELY_IMPORTANT>"

# Output context injection as JSON.
# Keep both shapes for compatibility:
# - Cursor hooks expect additional_context.
# - Claude hooks expect hookSpecificOutput.additionalContext.
cat <<EOF
{
  "additional_context": "${session_context}",
  "hookSpecificOutput": {
    "hookEventName": "SessionStart",
    "additionalContext": "${session_context}"
  }
}
EOF

exit 0
